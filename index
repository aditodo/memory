<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Enea Memory — Triathlon</title>
<style>
  /* === TOTEM DKST-LED43: 1080 x 1920 px === */
  :root{--navy:#15275f;--gold:#caa84a;--orange:#f39200;--shadow:0 26px 60px rgba(6,16,45,.5);}
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;-webkit-user-select:none;user-select:none}
  html,body{height:100%;overflow:hidden}
  body{font-family:"Segoe UI",system-ui,-apple-system,Roboto,Arial,sans-serif;background:#06112e;color:#fff;
       width:100vw;height:100vh;display:flex;align-items:center;justify-content:center}
  .stage{position:relative;width:1080px;height:1920px;flex:0 0 auto;transform-origin:center center;overflow:hidden;
         background:#0c1838 center/cover no-repeat;background-image:url("data:image/jpeg;base64,")}
  .bgvid{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0}
  .bg-overlay{position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(180deg,rgba(8,20,55,.45),rgba(8,18,48,.62))}
  .screen{position:absolute;inset:0;z-index:2;display:none;flex-direction:column}
  .screen.active{display:flex}

  /* START */
  #start{align-items:center;padding:0 70px 80px}
  .logo-enea{margin-top:230px;width:460px;filter:drop-shadow(0 8px 20px rgba(0,40,90,.5))}
  .btn-start{margin-top:70px;background:linear-gradient(180deg,#1f3576,#15275f);color:#fff;border:none;border-radius:90px;
    padding:48px 180px;font-size:108px;font-weight:800;letter-spacing:7px;cursor:pointer;
    box-shadow:0 30px 60px rgba(8,20,55,.55),inset 0 4px 0 rgba(255,255,255,.12);text-shadow:0 6px 16px rgba(0,0,0,.45)}
  .btn-start:active{transform:scale(.97)}
  .rank-card{margin-top:90px;width:100%;background:linear-gradient(180deg,rgba(20,34,80,.93),rgba(16,28,68,.93));
    border-radius:54px;padding:50px 46px 40px;box-shadow:var(--shadow);border:2px solid rgba(120,150,220,.2);backdrop-filter:blur(3px)}
  .rank-card h2{text-align:center;font-size:72px;font-weight:800;letter-spacing:5px;margin-bottom:34px}
  .rank-head{display:grid;grid-template-columns:110px 1fr auto;gap:30px;padding:0 28px 18px;font-size:28px;letter-spacing:3px;color:#8fa0cf;font-weight:700}
  .rank-head .c-time{text-align:right;min-width:230px}
  .rank-row{display:grid;grid-template-columns:110px 1fr auto;gap:30px;align-items:center;
    background:linear-gradient(90deg,rgba(202,168,74,.30),rgba(202,168,74,.10));border:2px solid rgba(202,168,74,.55);
    border-radius:36px;padding:28px;margin-bottom:18px;font-weight:700}
  .medal{width:80px;height:80px;display:flex;align-items:center;justify-content:center;border-radius:50%;
    background:radial-gradient(circle at 35% 30%,#ffd34d,#e0a019);box-shadow:0 4px 12px rgba(0,0,0,.3);font-size:36px;font-weight:800;color:#7a5500}
  .rank-row .nm{font-size:40px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .rank-row .tm{text-align:right;min-width:230px;font-variant-numeric:tabular-nums;font-size:40px}
  .rank-row.alt{background:rgba(255,255,255,.05);border-color:rgba(140,160,210,.25)}
  .rank-row.alt .medal{background:#46598f;color:#cdd8f5}
  .rank-more{display:block;width:100%;background:none;border:none;color:#fff;cursor:pointer;text-align:center;font-weight:800;letter-spacing:3px;font-size:34px;padding:28px 0 10px}
  .rank-empty{text-align:center;color:#9fb0d8;padding:30px 0;font-size:34px}

  /* GAME */
  #game{padding:46px 44px 60px}
  .g-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:34px}
  .g-top .logo-mini{width:230px}
  .g-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;margin-bottom:40px}
  .stat{background:linear-gradient(180deg,rgba(20,34,80,.9),rgba(14,26,64,.9));border:2px solid rgba(120,150,220,.2);border-radius:34px;padding:26px;text-align:center;backdrop-filter:blur(3px)}
  .stat .k{font-size:28px;letter-spacing:3px;color:#8fa0cf;font-weight:700;text-transform:uppercase}
  .stat .v{font-size:62px;font-weight:800;font-variant-numeric:tabular-nums;margin-top:6px}
  .board{display:grid;grid-template-columns:repeat(4,1fr);gap:34px}
  .card{aspect-ratio:1/1;perspective:1600px;cursor:pointer;background:none;border:none;padding:0}
  .inner{position:relative;width:100%;height:100%;transition:transform .5s cubic-bezier(.2,.8,.3,1);transform-style:preserve-3d}
  .card.flipped .inner,.card.matched .inner{transform:rotateY(180deg)}
  .face{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;border-radius:40px;
        backface-visibility:hidden;overflow:hidden;box-shadow:0 14px 30px rgba(6,16,45,.45)}
  .front{background:linear-gradient(160deg,#17326f,#0f2150);border:2px solid rgba(120,150,220,.25)}
  .front img{width:74%;height:auto}
  .back{transform:rotateY(180deg);background:#fff;border:2px solid rgba(120,150,220,.35)}
  .back img{width:100%;height:100%;object-fit:cover;display:block}
  .card.matched .face{box-shadow:0 0 0 7px var(--gold),0 14px 30px rgba(6,16,45,.45)}
  .card.matched{animation:pop .45s ease}
  @keyframes pop{0%{transform:scale(1)}40%{transform:scale(1.06)}100%{transform:scale(1)}}
  .g-actions{display:flex;justify-content:center;margin-top:46px}
  .btn-ghost{background:rgba(255,255,255,.14);color:#fff;border:2px solid rgba(255,255,255,.3);border-radius:30px;padding:28px 56px;font-weight:700;cursor:pointer;font-size:38px;backdrop-filter:blur(4px)}

  /* OVERLAYS */
  .overlay{position:absolute;inset:0;background:rgba(7,17,45,.85);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;padding:80px;z-index:30}
  .overlay.show{display:flex;animation:fade .3s ease}@keyframes fade{from{opacity:0}to{opacity:1}}
  .modal{background:#fff;color:#15275f;border-radius:54px;max-width:860px;width:100%;padding:80px 64px;text-align:center;box-shadow:var(--shadow);position:relative;overflow:hidden}
  .modal::before{content:"";position:absolute;top:0;left:0;right:0;height:18px;background:linear-gradient(90deg,#caa84a,#ffd34d)}
  .modal .trophy{font-size:150px;line-height:1}
  .modal h2{font-size:80px;margin:18px 0 12px}
  .modal p{color:#7d89a8;margin-bottom:24px;font-size:36px;line-height:1.4}
  .time-big{margin:34px 0 44px}
  .time-big span{display:block;font-size:30px;color:#7d89a8;text-transform:uppercase;letter-spacing:3px;font-weight:700;margin-bottom:8px}
  .time-big b{font-size:96px;font-variant-numeric:tabular-nums;letter-spacing:-1px}
  .modal input{width:100%;padding:40px 44px;border-radius:36px;border:4px solid rgba(140,160,210,.4);background:#f3f6fc;color:#15275f;font-size:48px;font-weight:600;outline:none;text-align:center;margin-bottom:36px}
  .modal input::placeholder{color:#a9b6d4}
  .modal input:focus{border-color:var(--orange)}
  .btn-go{width:100%;background:linear-gradient(180deg,#1f3576,#15275f);color:#fff;border:none;border-radius:90px;padding:44px;font-size:54px;font-weight:800;letter-spacing:3px;cursor:pointer;box-shadow:0 20px 44px rgba(8,20,55,.5)}
  .btn-go:active{transform:scale(.98)}
  .rmodal{background:linear-gradient(180deg,#1b2c66,#101c44);color:#fff;max-width:920px;width:100%;border-radius:54px;padding:64px 56px;box-shadow:var(--shadow);max-height:1500px;overflow:auto}
  .rmodal h2{text-align:center;letter-spacing:5px;margin-bottom:40px;font-size:64px}
  .btn-close{margin-top:40px;width:100%;background:rgba(255,255,255,.1);border:2px solid rgba(255,255,255,.25);color:#fff;border-radius:36px;padding:36px;font-weight:700;cursor:pointer;font-size:44px}
</style>
</head>
<body>
<div class="stage" id="stage">
  <video class="bgvid" autoplay loop muted playsinline disablepictureinpicture></video>
  <div class="bg-overlay"></div>

  <section class="screen active" id="start">
    <img class="logo-enea" src="data:image/png;base64," alt="Enea">
    <button class="btn-start" id="btnStart">START</button>
    <div class="rank-card">
      <h2>RANKING</h2>
      <div class="rank-head"><span>LP.</span><span>IMIĘ</span><span class="c-time">CZAS</span></div>
      <div id="rankTop"></div>
      <button class="rank-more" id="rankMore">ZOBACZ PEŁNY RANKING</button>
    </div>
  </section>

  <section class="screen" id="game">
    <div class="g-top">
      <img class="logo-mini" src="data:image/png;base64," alt="Enea">
      <button class="btn-ghost" id="btnQuit">Wyjdź</button>
    </div>
    <div class="g-stats">
      <div class="stat"><div class="k">Ruchy</div><div class="v" id="moves">0</div></div>
      <div class="stat"><div class="k">Pary</div><div class="v" id="pairs">0/8</div></div>
      <div class="stat"><div class="k">Czas</div><div class="v" id="time">00:00.000</div></div>
    </div>
    <div class="board" id="board"></div>
    <div class="g-actions"><button class="btn-ghost" id="btnRestart">Od nowa</button></div>
  </section>

  <div class="overlay" id="winOverlay">
    <div class="modal">
      <div class="trophy">🏅</div>
      <h2>Meta!</h2>
      <p>Wszystkie pary znalezione. Wpisz imię, aby zapisać czas.</p>
      <div class="time-big"><span>Twój czas</span><b id="winTime">00:00.000</b></div>
      <input id="playerName" maxlength="18" placeholder="Twoje imię" autocomplete="off">
      <button class="btn-go" id="btnSave">ZAPISZ WYNIK</button>
    </div>
  </div>
  <div class="overlay" id="rankOverlay">
    <div class="rmodal">
      <h2>PEŁNY RANKING</h2>
      <div class="rank-head" style="grid-template-columns:110px 1fr auto"><span>LP.</span><span>IMIĘ</span><span class="c-time">CZAS</span></div>
      <div id="rankFull"></div>
      <button class="btn-close" id="btnCloseRank">Zamknij</button>
    </div>
  </div>
</div>

<script>
// skalowanie sceny 1080x1920 do ekranu
(function(){
  const stage=document.getElementById("stage");
  function fit(){const s=Math.min(window.innerWidth/1080,window.innerHeight/1920);stage.style.transform="scale("+s+")";}
  addEventListener("resize",fit);addEventListener("orientationchange",fit);fit();
})();
// tlo wideo
(function(){
  try{
    const b64="",bin=atob(b64),len=bin.length,bytes=new Uint8Array(len);
    for(let i=0;i<len;i++)bytes[i]=bin.charCodeAt(i);
    const url=URL.createObjectURL(new Blob([bytes],{type:"video/mp4"}));
    const v=document.querySelector(".bgvid");v.src=url;
    const play=()=>{const pr=v.play&&v.play();if(pr&&pr.catch)pr.catch(()=>{});};
    v.addEventListener("loadeddata",play);play();
    addEventListener("touchstart",play,{once:true});addEventListener("click",play,{once:true});
    v.addEventListener("error",()=>{v.style.display="none";});
  }catch(e){const v=document.querySelector(".bgvid");if(v)v.style.display="none";}
})();

const LOGO="data:image/png;base64,";
const PAIRS={
  "czepek":{label:"Czepek i gogle",img:"data:image/jpeg;base64,"},
  "rower":{label:"Rower szosowy",img:"data:image/jpeg;base64,"},
  "buty":{label:"Buty biegowe",img:"data:image/jpeg;base64,"},
  "kask":{label:"Kask",img:"data:image/jpeg;base64,"},
  "plywak":{label:"P\u0142ywak",img:"data:image/jpeg;base64,"},
  "kolarz":{label:"Kolarz",img:"data:image/jpeg;base64,"},
  "biegacz":{label:"Biegacz",img:"data:image/jpeg;base64,"},
  "medal":{label:"Medal",img:"data:image/jpeg;base64,"},
};
const KEYS=Object.keys(PAIRS);
let ranking=[];   // wylacznie imie + czas

// ===========================================================
//  KONFIGURACJA BAZY WYNIKOW (Google Sheets / Apps Script)
//  Wklej ponizej adres URL swojego Apps Script dla gry MEMORY.
//  UWAGA: to musi byc OSOBNY adres niz dla gry 67 Speed!
//  (Memory sortuje rosnaco - wygrywa najkrotszy czas.)
//  Jesli zostawisz pusty ('') - gra dziala lokalnie (wyniki znikaja
//  po odswiezeniu strony).
const SHEETS_URL = '';
// ===========================================================

const useCloud = () => SHEETS_URL.trim().length > 0;

// Pobranie rankingu z arkusza
async function loadRanking(){
  if(!useCloud()){ renderRankTop(); renderRankFull(); return; }
  try{
    const r = await fetch(SHEETS_URL + '?action=scores&limit=50');
    const d = await r.json();
    ranking = (d.scores||[]).map(e=>({name:e.name, ms:e.score}));
  }catch(err){
    console.error('Nie udalo sie wczytac rankingu:', err);
  }
  renderRankTop(); renderRankFull();
}

// Wyslanie wyniku do arkusza. ms = czas w milisekundach.
async function pushScore(name, ms){
  if(!useCloud()){
    ranking.push({name:name, ms:ms});   // tryb lokalny
    return {ok:true};
  }
  const r = await fetch(SHEETS_URL, {
    method:'POST',
    headers:{'Content-Type':'text/plain;charset=utf-8'},
    body: JSON.stringify({name:name, score:ms})
  });
  return await r.json();
}

const $=s=>document.querySelector(s);
const screens={start:$("#start"),game:$("#game")};
function show(id){Object.values(screens).forEach(s=>s.classList.remove("active"));screens[id].classList.add("active");}
function fmtTime(ms){const m=Math.floor(ms/60000),s=Math.floor((ms%60000)/1000),mm=ms%1000;
  return String(m).padStart(2,"0")+":"+String(s).padStart(2,"0")+"."+String(mm).padStart(3,"0");}
function esc(s){return String(s).replace(/[&<>"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c]));}

function sorted(){return [...ranking].sort((a,b)=>a.ms-b.ms);}  // najszybszy = najlepszy
function renderRankTop(){const box=$("#rankTop");const s=sorted();
  if(!s.length){box.innerHTML='<div class="rank-empty">Brak wyników — zagraj pierwszy!</div>';return;}
  const r=s[0];
  box.innerHTML=`<div class="rank-row"><span class="medal">1</span><span class="nm">${esc(r.name)}</span><span class="tm">${fmtTime(r.ms)}</span></div>`;}
function renderRankFull(){const box=$("#rankFull");const s=sorted();
  if(!s.length){box.innerHTML='<div class="rank-empty">Brak wyników.</div>';return;}
  box.innerHTML=s.map((r,i)=>`<div class="rank-row ${i>0?'alt':''}"><span class="medal">${i+1}</span><span class="nm">${esc(r.name)}</span><span class="tm">${fmtTime(r.ms)}</span></div>`).join("");}

// preload zdjec
Object.values(PAIRS).forEach(p=>{const i=new Image();i.src=p.img;});

const board=$("#board");
let deck=[],first=null,lock=false,moves=0,matched=0,raf=null,startT=0,elapsed=0,finalMs=0;
function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
function tick(){elapsed=performance.now()-startT;$("#time").textContent=fmtTime(Math.floor(elapsed));raf=requestAnimationFrame(tick);}
function buildGame(){
  cancelAnimationFrame(raf);
  deck=shuffle(KEYS.flatMap(k=>[k,k]));
  first=null;lock=false;moves=0;matched=0;elapsed=0;
  $("#moves").textContent="0";$("#pairs").textContent="0/8";$("#time").textContent="00:00.000";
  board.innerHTML="";
  deck.forEach(k=>{const b=document.createElement("button");b.className="card";b.setAttribute("aria-label","Zakryta karta");
    b.innerHTML=`<div class="inner"><div class="face front"><img src="${LOGO}" alt="Enea"></div><div class="face back"><img src="${PAIRS[k].img}" alt="${esc(PAIRS[k].label)}"></div></div>`;
    b.addEventListener("click",()=>flip(b,k));board.appendChild(b);});
  startT=performance.now();raf=requestAnimationFrame(tick);
}
function flip(el,key){
  if(lock||el.classList.contains("flipped")||el.classList.contains("matched"))return;
  el.classList.add("flipped");
  if(!first){first={el,key};return;}
  moves++;$("#moves").textContent=moves;
  if(first.key===key){first.el.classList.add("matched");el.classList.add("matched");
    matched++;$("#pairs").textContent=matched+"/8";first=null;if(matched===KEYS.length)win();
  }else{lock=true;const a=first.el;setTimeout(()=>{a.classList.remove("flipped");el.classList.remove("flipped");first=null;lock=false;},850);}
}
function win(){cancelAnimationFrame(raf);finalMs=Math.floor(elapsed);
  $("#winTime").textContent=fmtTime(finalMs);$("#playerName").value="";
  setTimeout(()=>{$("#winOverlay").classList.add("show");$("#playerName").focus();},500);}

$("#btnStart").addEventListener("click",()=>{show("game");buildGame();});
$("#btnRestart").addEventListener("click",buildGame);
$("#btnQuit").addEventListener("click",()=>{cancelAnimationFrame(raf);show("start");});
$("#btnSave").addEventListener("click",async()=>{
  const v=$("#playerName").value.trim()||"Gracz";
  const btn=$("#btnSave"); const prev=btn.textContent;
  btn.disabled=true; btn.textContent="ZAPISYWANIE...";
  try{
    await pushScore(v,finalMs);   // zapis do arkusza Google
    await loadRanking();          // odswiez ranking z bazy
  }catch(err){
    alert("Nie udalo sie zapisac wyniku. Sprawdz polaczenie z internetem.");
  }
  btn.disabled=false; btn.textContent=prev;
  $("#winOverlay").classList.remove("show");show("start");$("#rankOverlay").classList.add("show");});
$("#playerName").addEventListener("keydown",e=>{if(e.key==="Enter")$("#btnSave").click();});
$("#rankMore").addEventListener("click",()=>{renderRankFull();$("#rankOverlay").classList.add("show");});
$("#btnCloseRank").addEventListener("click",()=>$("#rankOverlay").classList.remove("show"));
loadRanking();
</script>
</body>
</html>
